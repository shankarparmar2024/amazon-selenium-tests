# Copy this file to ".env" and fill in your values.
# The .env file is git-ignored so your credentials stay private.

# ── Browser (local runs) ──────────────────────────────────────────────────────
BROWSER=chrome          # chrome | firefox | edge
HEADLESS=false          # true to run without opening a window

# ── LambdaTest (only needed when using --lambdatest flag) ────────────────────
LT_USERNAME=your_lambdatest_username
LT_ACCESS_KEY=your_lambdatest_access_key
